rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && 
        request.auth.token.email in [
          'cardoza.kian@gmail.com',
          'cardoza.keigs@gmail.com',
          'cardoza.joseph@gmail.com'
        ];
    }

    function isUserDoc(userId) {
      return request.auth.uid == userId;
    }

    function isRegistered() {
      // A user is considered fully registered only if their role is NOT 'pending'
      return signedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'pending')
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function canPlaceBet(matchId, resourceData) {
      return signedIn() && (
        isAdmin() || 
        (
          resourceData.userId == request.auth.uid &&
          !resourceData.isDefault &&
          request.time < get(/databases/$(database)/documents/matches/$(matchId)).data.kickoffTimeIST &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.status in ['upcoming', 'betting_open'] &&
          (
            // If team A wins, goal A > goal B
            (resourceData.teamPrediction == 'teamA' && resourceData.goalsTeamA > resourceData.goalsTeamB) ||
            // If team B wins, goal B > goal A
            (resourceData.teamPrediction == 'teamB' && resourceData.goalsTeamB > resourceData.goalsTeamA) ||
            // If draw, goal A == goal B
            (resourceData.teamPrediction == 'draw' && resourceData.goalsTeamA == resourceData.goalsTeamB)
          )
        )
      );
    }

    // User profiles rules
    match /users/{userId} {
      allow read: if signedIn() && (isAdmin() || isUserDoc(userId));
      // Admins can create/update any profile.
      // Users can create their own pending join request profile if they don't already have one.
      allow create: if signedIn() && (isAdmin() || (isUserDoc(userId) && !exists(/databases/$(database)/documents/users/$(userId))));
      allow update: if signedIn() && isAdmin();
      allow delete: if signedIn() && isAdmin();
    }

    // Matches rules
    match /matches/{matchId} {
      allow read: if isRegistered();
      allow write: if isAdmin();
    }

    // Bets rules
    match /bets/{betId} {
      // Users can read their own bets.
      // Users can only read other users' bets after the match has kicked off or status is closed/completed/postponed
      allow read: if signedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.status in ['betting_closed', 'completed', 'live', 'postponed'] ||
        request.time >= get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoffTimeIST
      );
      
      // Users can place or edit their bets before lock time, as long as the match status is upcoming/open.
      allow create: if canPlaceBet(request.resource.data.matchId, request.resource.data);
      allow update: if canPlaceBet(request.resource.data.matchId, request.resource.data);
      allow delete: if isAdmin();
    }

    // Leaderboard rules
    match /leaderboard/{userId} {
      allow read: if isRegistered();
      allow write: if isAdmin();
    }

    // Kitty logs rules
    match /kitty/{kittyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Settlement backups rules
    match /settlement_backups/{matchId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }


    // Global Settings rules
    match /settings/global {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
